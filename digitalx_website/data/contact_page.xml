<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="contact_page" name="DX Contact Page">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty">
                <style>
                    .cc-contact-hero {
                        padding: 112px 0 90px;
                        background:
                            linear-gradient(180deg, rgba(33,37,41,0.78) 0%, rgba(33,37,41,0.52) 100%),
                            url('/digitalx_website/static/src/img/besco/lifestyle/showers.jpg') center/cover no-repeat;
                        color: #fff;
                    }
                    .cc-contact-shell { max-width: 1240px; margin: 0 auto; padding: 0 28px; }
                    .cc-contact-badge {
                        display: inline-flex;
                        align-items: center;
                        gap: 8px;
                        padding: 9px 16px;
                        border-radius: 999px;
                        background: rgba(192,57,43,0.14);
                        color: #f1f2f4;
                        font-size: 12px;
                        font-weight: 800;
                        letter-spacing: 0.14em;
                        text-transform: uppercase;
                    }
                    .cc-contact-badge:before { content: ''; width: 7px; height: 7px; border-radius: 50%; background: var(--dx-primary); }
                    .cc-contact-title {
                        margin: 18px 0 14px;
                        max-width: 760px;
                        font-family: var(--dx-font-head);
                        font-size: clamp(2.4rem, 4vw, 4.8rem);
                        line-height: 0.98;
                        letter-spacing: -0.03em;
                    }
                    .cc-contact-copy { max-width: 650px; margin: 0; color: rgba(255,255,255,0.82); font-size: 16px; line-height: 1.85; }
                    .cc-contact-actions { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 28px; }
                    .cc-contact-actions a {
                        display: inline-flex;
                        align-items: center;
                        justify-content: center;
                        min-height: 52px;
                        padding: 0 24px;
                        border-radius: 999px;
                        text-decoration: none !important;
                        font-size: 14px;
                        font-weight: 800;
                    }
                    .cc-contact-actions a:first-child {
                        background: linear-gradient(135deg, var(--dx-primary), var(--dx-primary-hover));
                        color: #fff;
                    }
                    .cc-contact-actions a:last-child {
                        background: rgba(255,255,255,0.12);
                        border: 1px solid rgba(255,255,255,0.32);
                        color: #fff;
                    }
                    .cc-contact-section { padding: 92px 0; background: var(--dx-ivory-strong); }
                    .cc-contact-grid { display: grid; grid-template-columns: 0.92fr 1.08fr; gap: 28px; }
                    .cc-contact-panel,
                    .cc-contact-form {
                        border-radius: 32px;
                        background: linear-gradient(180deg, #fff 0%, var(--dx-ivory) 100%);
                        border: 1px solid rgba(63,49,36,0.08);
                        box-shadow: var(--dx-shadow);
                    }
                    .cc-contact-panel { padding: 32px; }
                    .cc-contact-panel h2,
                    .cc-contact-form h2 {
                        margin: 0 0 12px;
                        font-family: var(--dx-font-head);
                        font-size: 36px;
                        line-height: 1.04;
                        color: var(--dx-charcoal);
                    }
                    .cc-contact-panel > p,
                    .cc-contact-form > p { margin: 0 0 24px; color: var(--dx-copy); font-size: 15px; line-height: 1.85; }
                    .cc-contact-card {
                        padding: 20px 22px;
                        border-radius: 24px;
                        background: rgba(255,255,255,0.82);
                        border: 1px solid rgba(63,49,36,0.08);
                        margin-bottom: 14px;
                    }
                    .cc-contact-card:last-child { margin-bottom: 0; }
                    .cc-contact-card h3 { margin: 0 0 6px; font-size: 17px; font-weight: 800; color: var(--dx-charcoal); }
                    .cc-contact-card p,
                    .cc-contact-card a { margin: 0; color: var(--dx-copy); font-size: 15px; line-height: 1.8; text-decoration: none !important; }
                    .cc-contact-map {
                        overflow: hidden;
                        border-radius: 26px;
                        margin-top: 18px;
                        border: 1px solid rgba(63,49,36,0.08);
                    }
                    .cc-contact-map iframe { display: block; width: 100%; height: 280px; border: 0; }
                    .cc-contact-form { padding: 32px; }
                    .cc-form-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; }
                    .cc-form-group { margin-bottom: 16px; }
                    .cc-form-group label {
                        display: block;
                        margin-bottom: 7px;
                        font-size: 13px;
                        font-weight: 800;
                        color: var(--dx-charcoal);
                        letter-spacing: 0.08em;
                        text-transform: uppercase;
                    }
                    .cc-form-group input,
                    .cc-form-group textarea {
                        width: 100%;
                        padding: 13px 16px;
                        border-radius: 16px;
                        border: 1px solid rgba(63,49,36,0.12);
                        background: rgba(255,255,255,0.88);
                        color: var(--dx-charcoal);
                        font-size: 15px;
                    }
                    .cc-form-group textarea { min-height: 160px; resize: vertical; }
                    .cc-form-group input:focus,
                    .cc-form-group textarea:focus {
                        outline: none;
                        border-color: rgba(192,57,43,0.5);
                        box-shadow: 0 0 0 4px rgba(192,57,43,0.14);
                    }
                    .cc-submit {
                        width: 100%;
                        min-height: 54px;
                        border: 0;
                        border-radius: 18px;
                        background: linear-gradient(135deg, var(--dx-charcoal), var(--dx-charcoal-soft));
                        color: #fff;
                        font-size: 15px;
                        font-weight: 800;
                    }
                    .cc-form-note { margin: 12px 0 0; text-align: center; color: var(--dx-copy); font-size: 13px; }
                    @media (max-width: 991px) {
                        .cc-contact-grid,
                        .cc-form-grid { grid-template-columns: 1fr; }
                    }
                    @media (max-width: 767px) {
                        .cc-contact-shell { padding: 0 18px; }
                        .cc-contact-hero { padding: 96px 0 72px; }
                        .cc-contact-section { padding: 72px 0; }
                        .cc-contact-panel,
                        .cc-contact-form { padding: 26px; }
                    }
                </style>

                <section class="cc-contact-hero">
                    <div class="cc-contact-shell">
                        <span class="cc-contact-badge">Contact Craik &amp; Comfort</span>
                        <h1 class="cc-contact-title">Speak with us about products, collections, or your next bathroom project.</h1>
                        <p class="cc-contact-copy">Use the direct contact options below for quick guidance, or send a detailed enquiry through the form for quotations, fit-out discussions, or curated product recommendations.</p>
                        <div class="cc-contact-actions">
                            <a href="tel:+353879394509">Call +353 87 939 4509</a>
                            <a href="https://wa.me/353879394509" target="_blank" rel="noopener noreferrer">WhatsApp Support</a>
                        </div>
                    </div>
                </section>

                <section class="cc-contact-section">
                    <div class="cc-contact-shell">
                        <div class="cc-contact-grid">
                            <div class="cc-contact-panel">
                                <h2>Reach the team directly.</h2>
                                <p>The contact experience has been rewritten around consultation, support, and premium bathroom enquiries instead of the previous client profile.</p>

                                <div class="cc-contact-card">
                                    <h3>Email</h3>
                                    <p><a href="mailto:info@craikcomfort.ie">info@craikcomfort.ie</a></p>
                                </div>
                                <div class="cc-contact-card">
                                    <h3>Phone</h3>
                                    <p><a href="tel:+353879394509">+353 87 939 4509</a></p>
                                </div>
                                <div class="cc-contact-card">
                                    <h3>WhatsApp</h3>
                                    <p><a href="https://wa.me/353879394509" target="_blank" rel="noopener noreferrer">Chat with the client care team</a></p>
                                </div>
                                <div class="cc-contact-card">
                                    <h3>Location</h3>
                                    <p>D15XC91, Ireland</p>
                                </div>

                                <div class="cc-contact-map">
                                    <iframe src="https://www.google.com/maps?q=D15XC91%2C%20Ireland&amp;z=14&amp;output=embed" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Craik and Comfort contact location"></iframe>
                                </div>
                            </div>

                            <div class="cc-contact-form">
                                <h2>Send a project enquiry.</h2>
                                <p>This form is positioned for bathroom planning, quotation requests, design consultation, and product support.</p>

                                <form action="/website/form/" method="post" class="s_website_form" enctype="multipart/form-data" data-model_name="mail.mail" data-success-mode="redirect" data-success-page="/contactus">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <input type="hidden" name="email_to" value="info@craikcomfort.ie"/>

                                    <div class="cc-form-grid">
                                        <div class="cc-form-group">
                                            <label for="cc_name">Full Name</label>
                                            <input type="text" id="cc_name" name="name" required="required" placeholder="Your full name"/>
                                        </div>
                                        <div class="cc-form-group">
                                            <label for="cc_phone">Phone / WhatsApp</label>
                                            <input type="tel" id="cc_phone" name="phone" required="required" placeholder="+353 ..."/>
                                        </div>
                                    </div>

                                    <div class="cc-form-grid">
                                        <div class="cc-form-group">
                                            <label for="cc_email">Email</label>
                                            <input type="email" id="cc_email" name="email_from" required="required" placeholder="name@example.com"/>
                                        </div>
                                        <div class="cc-form-group">
                                            <label for="cc_company">Company</label>
                                            <input type="text" id="cc_company" name="company" placeholder="Optional"/>
                                        </div>
                                    </div>

                                    <div class="cc-form-group">
                                        <label for="cc_subject">Subject</label>
                                        <input type="text" id="cc_subject" name="subject" required="required" placeholder="Quotation, product advice, renovation project..."/>
                                    </div>

                                    <div class="cc-form-group">
                                        <label for="cc_message">Message</label>
                                        <textarea id="cc_message" name="body_html" required="required" placeholder="Tell us about the products, finishes, or project scope you need help with."></textarea>
                                    </div>

                                    <button type="submit" class="cc-submit s_website_form_send">Send Enquiry</button>
                                    <p class="cc-form-note">Your message routes to the new Craik &amp; Comfort contact address.</p>
                                </form>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>

    <record id="contact_page_record" model="website.page">
        <field name="name">Contact Craik &amp; Comfort</field>
        <field name="url">/contactus</field>
        <field name="website_published">True</field>
        <field name="view_id" ref="contact_page"/>
        <field name="website_id" ref="website.default_website"/>
    </record>
</odoo>
