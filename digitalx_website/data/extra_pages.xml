<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="0">
        <template id="dx_extra_page_styles" name="DX Extra Page Styles" inherit_id="website.layout" priority="40">
            <xpath expr="//head" position="inside">
                <style>
                    .cc-studio-hero {
                        padding: 110px 0 90px;
                        background:
                            linear-gradient(180deg, rgba(33,37,41,0.78) 0%, rgba(33,37,41,0.52) 100%),
                            url('/digitalx_website/static/src/img/besco/lifestyle/bath-travel.jpg') center/cover no-repeat;
                        color: #fff;
                    }
                    .cc-page-shell { max-width: 1240px; margin: 0 auto; padding: 0 28px; }
                    .cc-page-badge {
                        display: inline-flex;
                        align-items: center;
                        gap: 8px;
                        padding: 9px 16px;
                        border-radius: 999px;
                        background: rgba(192,57,43,0.14);
                        color: #f1f2f4;
                        font-size: 12px;
                        font-weight: 800;
                        letter-spacing: 0.14em;
                        text-transform: uppercase;
                    }
                    .cc-page-badge:before { content: ''; width: 7px; height: 7px; border-radius: 50%; background: var(--dx-primary); }
                    .cc-page-title {
                        margin: 18px 0 14px;
                        max-width: 760px;
                        font-family: var(--dx-font-head);
                        font-size: clamp(2.3rem, 4vw, 4.6rem);
                        line-height: 0.98;
                        letter-spacing: -0.03em;
                    }
                    .cc-page-copy { max-width: 660px; margin: 0; color: rgba(255,255,255,0.82); font-size: 16px; line-height: 1.85; }
                    .cc-studio-section { padding: 92px 0; background: var(--dx-ivory-strong); }
                    .cc-studio-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; align-items: center; }
                    .cc-studio-card {
                        overflow: hidden;
                        border-radius: 32px;
                        background: linear-gradient(180deg, #fff 0%, var(--dx-ivory) 100%);
                        border: 1px solid rgba(63,49,36,0.08);
                        box-shadow: var(--dx-shadow);
                    }
                    .cc-studio-card img { width: 100%; height: 100%; min-height: 520px; object-fit: cover; }
                    .cc-studio-body { padding: 36px; }
                    .cc-studio-body h2,
                    .cc-collections-head h2,
                    .cc-care-head h2 {
                        margin: 0 0 14px;
                        font-family: var(--dx-font-head);
                        font-size: 38px;
                        line-height: 1.04;
                        color: var(--dx-charcoal);
                    }
                    .cc-studio-body p,
                    .cc-collections-head p,
                    .cc-care-head p { margin: 0 0 14px; color: var(--dx-copy); font-size: 15px; line-height: 1.9; }
                    .cc-studio-metrics { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 28px; }
                    .cc-studio-metric,
                    .cc-collection-card,
                    .cc-care-card {
                        padding: 24px;
                        border-radius: 24px;
                        background: rgba(255,255,255,0.84);
                        border: 1px solid rgba(63,49,36,0.08);
                    }
                    .cc-studio-metric strong { display: block; margin-bottom: 8px; font-size: 30px; color: var(--dx-brass-deep); }
                    .cc-studio-metric span { color: var(--dx-copy); font-size: 14px; line-height: 1.75; }
                    .cc-collections-section,
                    .cc-care-section { padding: 92px 0; background: var(--dx-ivory); }
                    .cc-collections-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; margin-top: 34px; }
                    .cc-collection-card img { width: 100%; height: 230px; object-fit: cover; border-radius: 18px; margin-bottom: 18px; }
                    .cc-collection-card h3,
                    .cc-care-card h3 { margin: 0 0 8px; font-size: 20px; font-weight: 800; color: var(--dx-charcoal); }
                    .cc-collection-card p,
                    .cc-care-card p,
                    .cc-care-card li { margin: 0; color: var(--dx-copy); font-size: 14px; line-height: 1.8; }
                    .cc-care-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 18px; margin-top: 34px; }
                    .cc-care-card ul { margin: 10px 0 0; padding-left: 18px; }
                    .cc-care-contact {
                        margin-top: 26px;
                        padding: 28px;
                        border-radius: 28px;
                        background: linear-gradient(120deg, var(--dx-charcoal) 0%, var(--dx-charcoal-soft) 65%, rgba(192,57,43,0.96) 160%);
                        color: #fff;
                    }
                    .cc-care-contact h3 { margin: 0 0 10px; font-size: 28px; font-family: var(--dx-font-head); }
                    .cc-care-contact p,
                    .cc-care-contact a { margin: 0; color: rgba(255,255,255,0.82); font-size: 15px; line-height: 1.85; text-decoration: none !important; }
                    @media (max-width: 991px) {
                        .cc-studio-grid,
                        .cc-studio-metrics,
                        .cc-collections-grid,
                        .cc-care-grid { grid-template-columns: 1fr; }
                    }
                    @media (max-width: 767px) {
                        .cc-page-shell { padding: 0 18px; }
                        .cc-studio-hero { padding: 96px 0 72px; }
                        .cc-studio-section,
                        .cc-collections-section,
                        .cc-care-section { padding: 72px 0; }
                        .cc-studio-body { padding: 28px; }
                        .cc-studio-card img { min-height: 360px; }
                    }
                </style>
            </xpath>
        </template>

