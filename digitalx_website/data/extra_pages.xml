        <record id="dx_company_page" model="website.page">
            <field name="name">Showroom Experience</field>
            <field name="url">/company</field>
            <field name="view_id" ref="dx_company_content"/>
            <field name="website_id" ref="website.default_website"/>
            <field name="website_indexed" eval="True"/>
            <field name="is_published" eval="True"/>
        </record>

        <template id="dx_partners_content" name="DX Partners Page" key="digitalx_website.dx_partners_content">
            <t t-call="website.layout">
                <div id="wrap" class="oe_structure">
                    <section class="cc-collections-section">
                        <div class="cc-page-shell">
                            <div class="cc-collections-head">
                                <span class="cc-page-badge" style="color:#f1f2f4;background:rgba(192,57,43,0.14);">Collections</span>
                                <h2>Collections arranged around mood, material, and bathroom use.</h2>
                                <p>These collection groupings give the catalog more personality and make it easier to imagine coordinated rooms, not just individual pieces.</p>
                            </div>
                            <div class="cc-collections-grid">
                                <div class="cc-collection-card">
                                    <img src="/digitalx_website/static/src/img/besco/categories/ceramics.jpg" alt="Stone and marble mood"/>
                                    <h3>Stone &amp; Marble Mood</h3>
                                    <p>Quiet neutrals, warm veining, and architectural surfaces that anchor premium bathroom schemes.</p>
                                </div>
                                <div class="cc-collection-card">
                                    <img src="/digitalx_website/static/src/img/besco/categories/faucets.jpg" alt="Brassware collection"/>
                                    <h3>Brushed Brass Detail</h3>
                                    <p>Metallic accents that bring warmth and contrast to white ceramics, glass, and natural textures.</p>
                                </div>
                                <div class="cc-collection-card">
                                    <img src="/digitalx_website/static/src/img/besco/categories/enclosures.jpg" alt="Glass enclosure collection"/>
                                    <h3>Minimal Glass Systems</h3>
                                    <p>Enclosures and screens that keep the room visually open while improving function and finish.</p>
                                </div>
                                <div class="cc-collection-card">
                                    <img src="/digitalx_website/static/src/img/besco/lifestyle/aspen.jpg" alt="Statement basin collection"/>
                                    <h3>Statement Basins</h3>
                                    <p>Sculptural forms and elevated countertop presence for stronger vanity compositions.</p>
                                </div>
                                <div class="cc-collection-card">
                                    <img src="/digitalx_website/static/src/img/besco/categories/bathtubs.jpg" alt="Bath collection"/>
                                    <h3>Contemporary Bathing</h3>
                                    <p>Bath-led looks designed around comfort, clean lines, and a calmer end-of-day experience.</p>
                                </div>
                                <div class="cc-collection-card">
                                    <img src="/digitalx_website/static/src/img/besco/categories/shower-trays.jpg" alt="Compact bathroom collection"/>
                                    <h3>Compact Smart Layouts</h3>
                                    <p>Selections for smaller footprints where proportion, practicality, and simplicity matter most.</p>
                                </div>
                            </div>
                        </div>
                    </section>
                </div>
            </t>
        </template>

        <record id="dx_partners_page" model="website.page">
