            <field name="url">/collections</field>
            <field name="view_id" ref="dx_partners_content"/>
            <field name="website_id" ref="website.default_website"/>
            <field name="website_indexed" eval="True"/>
            <field name="is_published" eval="True"/>
        </record>

        <template id="dx_warranty_content" name="DX Warranty Page" key="digitalx_website.dx_warranty_content">
            <t t-call="website.layout">
                <div id="wrap" class="oe_structure">
                    <section class="cc-care-section">
                        <div class="cc-page-shell">
                            <div class="cc-care-head">
                                <span class="cc-page-badge" style="color:#f1f2f4;background:rgba(192,57,43,0.14);">Customer Care</span>
                                <h2>Support that fits the premium position of the brand.</h2>
                                <p>This page replaces the old warranty-only model with broader customer care guidance covering enquiries, product help, and after-sales communication.</p>
                            </div>
                            <div class="cc-care-grid">
                                <div class="cc-care-card">
                                    <h3>Before You Order</h3>
                                    <p>Use the contact form or WhatsApp to confirm dimensions, finishes, category suitability, or cross-product coordination before placing larger orders.</p>
                                </div>
                                <div class="cc-care-card">
                                    <h3>After-Sales Support</h3>
                                    <p>Our communication flow is positioned around prompt follow-up, practical product guidance, and clearer routing for project or retail queries.</p>
                                </div>
                                <div class="cc-care-card">
                                    <h3>Returns &amp; Care Notes</h3>
                                    <ul>
                                        <li>Inspect items promptly after delivery.</li>
                                        <li>Keep packaging until installation planning is complete.</li>
                                        <li>Share images and order details when reporting issues.</li>
                                    </ul>
                                </div>
                                <div class="cc-care-card" id="payment-methods">
                                    <h3>Payment Methods</h3>
                                    <p>Available payment options are shown during checkout before order confirmation. For larger orders or project-based purchases, contact the team to confirm the preferred payment route in advance.</p>
                                </div>
                            </div>
                            <div class="cc-care-contact">
                                <h3>Need direct help?</h3>
                                <p><a href="mailto:info@craikcomfort.ie">info@craikcomfort.ie</a><br/><a href="tel:+353879394509">+353 87 939 4509</a><br/><a href="https://wa.me/353879394509" target="_blank" rel="noopener noreferrer">WhatsApp Support</a><br/>D15XC91, Ireland</p>
                            </div>
                        </div>
                    </section>
                </div>
            </t>
        </template>

        <record id="dx_warranty_page" model="website.page">
            <field name="name">Customer Care</field>
            <field name="url">/customer-care</field>
            <field name="view_id" ref="dx_warranty_content"/>
            <field name="website_id" ref="website.default_website"/>
            <field name="website_indexed" eval="True"/>
            <field name="is_published" eval="True"/>
