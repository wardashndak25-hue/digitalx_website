<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="dx_global_styles" name="DX Global Styles" inherit_id="website.layout" priority="1">
        <xpath expr="//head" position="inside">
            <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&amp;family=Roboto:wght@400;500;700&amp;family=Tajawal:wght@400;500;700;800&amp;display=swap" rel="stylesheet"/>
            <style>
                :root {
                    --dx-ivory: #f1f2f4;
                    --dx-ivory-strong: #ffffff;
                    --dx-stone: #e9ecef;
                    --dx-sand: #dee2e6;
                    --dx-brass: #c0392b;
                    --dx-brass-deep: #9a2e22;
                    --dx-secondary: #c0392b;
                    --dx-charcoal: #212529;
                    --dx-charcoal-soft: #343a40;
                    --dx-copy: #495057;
                    --dx-primary: #c0392b;
                    --dx-primary-hover: #9a2e22;
                    --dx-dark: #212529;
                    --dx-gray-500: #6c757d;
                    --dx-gray-700: #495057;
                    --dx-gray-900: #212529;
                    --dx-line: rgba(33, 37, 41, 0.12);
                    --dx-shadow: 0 24px 60px -36px rgba(33, 37, 41, 0.28);
                    --dx-radius-lg: 22px;
                    --dx-radius-xl: 32px;
                    --dx-font-body: 'Roboto', sans-serif;
                    --dx-font-head: 'IBM Plex Sans', sans-serif;
                    --dx-font-ar: 'Tajawal', sans-serif;
                }
                html, body, #wrapwrap {
                    background: var(--dx-ivory-strong);
                    color: var(--dx-charcoal);
                    font-family: var(--dx-font-body);
                    width: 100%;
                    max-width: 100%;
                    overflow-x: hidden;
                }
                html[dir="rtl"] body,
                html[dir="rtl"] #wrapwrap {
                    font-family: var(--dx-font-ar);
                }
                .dx-shell {
                    max-width: 1320px;
                    margin: 0 auto;
                    padding: 0 28px;
                }
                @media (max-width: 767px) {
                    .dx-shell { padding: 0 18px; }
                }
                .dx-topbar {
                    background: linear-gradient(90deg, var(--dx-charcoal) 0%, var(--dx-charcoal-soft) 100%);
                    color: rgba(255,255,255,0.72);
                    font-size: 12px;
                    letter-spacing: 0.02em;
                }
                .dx-topbar-inner {
                    display: flex;
                    align-items: center;
                    justify-content: space-between;
                    gap: 16px;
                    min-height: 42px;
                }
                .dx-topbar-copy {
                    display: flex;
                    align-items: center;
                    gap: 18px;
                    flex-wrap: wrap;
                }
                .dx-topbar a {
                    color: rgba(255,255,255,0.84) !important;
                    text-decoration: none !important;
                }
                .dx-topbar a:hover { color: #fff !important; }
                .dx-header-main {
                    position: sticky;
                    top: 0;
                    z-index: 1000;
                    backdrop-filter: blur(14px);
                    background: rgba(255, 255, 255, 0.96);
                    border-bottom: 1px solid var(--dx-line);
                }
                .dx-header-row {
                    display: flex;
                    align-items: center;
                    justify-content: space-between;
                    gap: 22px;
                    flex-wrap: nowrap;
                    min-height: 94px;
                }
                .dx-header-row > .d-flex.flex-grow-1 {
                    min-width: 0;
                }
                .dx-logo-card {
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    padding: 0;
                    border-radius: 0;
                    background: transparent;
                    box-shadow: none;
                    text-decoration: none !important;
                    flex-shrink: 0;
                }
                .dx-logo-card img {
                    width: auto;
                    height: 48px;
                    display: block;
                }
                .dx-nav {
                    display: flex;
                    flex-direction: row;
                    align-items: center;
                    gap: 20px;
                    margin: 0 auto;
                    padding: 0;
                    list-style: none;
                }
                .dx-nav > li {
                    list-style: none;
                }
                .dx-nav-link {
                    position: relative;
                    display: inline-flex;
                    align-items: center;
                    gap: 8px;
                    border: 0;
                    background: transparent;
                    padding: 0;
                    color: var(--dx-charcoal) !important;
                    font-size: 14px;
                    font-weight: 700;
                    letter-spacing: 0.01em;
                    text-decoration: none !important;
                }
                .dx-nav-link::after {
                    content: '';
                    position: absolute;
                    inset-inline: 0;
                    bottom: -8px;
                    height: 2px;
                    border-radius: 999px;
                    background: linear-gradient(90deg, var(--dx-brass), #d7b073);
                    transform: scaleX(0);
                    transform-origin: center;
                    transition: transform 0.24s ease;
                }
                .dx-nav-link:hover::after,
                .dx-nav-link.active::after { transform: scaleX(1); }
                .dx-nav-menu {
                    position: absolute;
                    display: block;
                    top: calc(100% + 18px);
                    inset-inline-start: 0;
                    min-width: 260px;
                    padding: 14px;
                    border-radius: 24px;
                    background: rgba(255,255,255,0.98);
                    border: 1px solid rgba(33,37,41,0.08);
                    box-shadow: var(--dx-shadow);
                    opacity: 0;
                    visibility: hidden;
                    transform: translateY(10px);
                    transition: opacity 0.22s ease, transform 0.22s ease, visibility 0.22s ease;
                }
                .dx-nav .dropdown:hover > .dx-nav-menu {
                    opacity: 1;
                    visibility: visible;
                    transform: translateY(0);
                }
                .dx-nav-menu a {
                    display: block;
                    padding: 11px 14px;
                    border-radius: 16px;
                    color: var(--dx-charcoal) !important;
                    text-decoration: none !important;
                    font-size: 14px;
                    font-weight: 700;
                }
                .dx-nav-menu a:hover {
                    background: rgba(192,57,43,0.1);
                    color: var(--dx-primary-hover) !important;
                }
                .dx-actions {
                    display: flex;
                    flex-direction: row;
                    align-items: center;
                    gap: 10px;
                    flex-shrink: 0;
                    list-style: none;
                    margin: 0;
                    padding: 0;
                }
                .dx-actions li {
                    list-style: none;
                }
                .dx-text-link,
                .dx-icon-pill,
                .dx-cart-pill {
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    gap: 8px;
                    min-height: 44px;
                    padding: 0 16px;
                    border-radius: 999px;
                    border: 1px solid var(--dx-line);
                    background: rgba(241,242,244,0.88);
                    color: var(--dx-charcoal) !important;
                    font-size: 13px;
                    font-weight: 700;
                    text-decoration: none !important;
                }
                .dx-text-link:hover,
                .dx-icon-pill:hover,
                .dx-cart-pill:hover {
                    border-color: rgba(192,57,43,0.26);
                    background: rgba(192,57,43,0.08);
                    color: var(--dx-primary-hover) !important;
                }
                .dx-cart-pill strong {
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    min-width: 22px;
                    height: 22px;
                    padding: 0 6px;
                    border-radius: 999px;
                    background: var(--dx-brass);
                    color: #fff;
                    font-size: 11px;
                }
                .dx-cta-link {
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    min-height: 48px;
                    padding: 0 20px;
                    border-radius: 999px;
                    background: linear-gradient(135deg, var(--dx-primary), var(--dx-primary-hover));
                    color: #fff !important;
                    font-size: 13px;
                    font-weight: 800;
                    text-decoration: none !important;
                    box-shadow: 0 18px 30px -22px rgba(192,57,43,0.4);
                }
                .dx-cta-link:hover {
                    background: linear-gradient(135deg, var(--dx-primary-hover), var(--dx-primary));
                    color: #fff !important;
                }
                .dx-mobile-toggle {
                    width: 48px;
                    height: 48px;
                    border: 1px solid var(--dx-line);
                    border-radius: 16px;
                    background: rgba(255,255,255,0.94);
                    color: var(--dx-charcoal);
                }
                .dx-mobile-toggle svg {
                    width: 22px;
                    height: 22px;
                }
                .dx-mobile-panel.offcanvas {
                    --bs-offcanvas-width: min(24rem, calc(100% - 18px));
                    width: min(24rem, calc(100vw - 18px));
                    max-width: calc(100vw - 18px);
                    border: 0;
                    background: linear-gradient(180deg, #ffffff 0%, var(--dx-ivory) 100%);
                }
                .dx-mobile-panel .offcanvas-body {
                    padding: 24px 20px 32px;
                    overflow-y: auto;
                    overflow-x: hidden;
                }
                .dx-mobile-panel .offcanvas-body > *,
                .dx-mobile-panel .navbar-nav,
                .dx-mobile-panel .top_menu,
                .dx-mobile-panel .top_menu > li,
                .dx-mobile-panel .top_menu > li > .accordion,
                .dx-mobile-panel .accordion,
                .dx-mobile-panel .accordion-item,
                .dx-mobile-panel .accordion-body,
                .dx-mobile-panel .dropdown-menu,
                .dx-mobile-panel .o_mega_nav,
                .dx-mobile-panel div.o_mega_menu,
                .dx-mobile-panel .o_mega_menu section {
                    width: 100%;
                    max-width: 100%;
                    min-width: 0;
                }
                .dx-mobile-logo {
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    padding: 0;
                    border-radius: 0;
                    background: transparent;
                    text-decoration: none !important;
                    margin-bottom: 22px;
                }
                .dx-mobile-logo img {
                    height: 52px;
                    width: auto;
                }
                .dx-mobile-links {
                    display: grid;
                    gap: 10px;
                }
                .dx-mobile-links a {
                    display: block;
                    padding: 14px 16px;
                    border-radius: 18px;
                    border: 1px solid rgba(33,37,41,0.08);
                    background: rgba(255,255,255,0.78);
                    color: var(--dx-charcoal) !important;
                    font-size: 14px;
                    font-weight: 700;
                    text-decoration: none !important;
                }
                .dx-mobile-links a:hover {
                    background: rgba(192,57,43,0.08);
                    color: var(--dx-primary-hover) !important;
                }
                .dx-mobile-panel .top_menu {
                    gap: 0;
                    padding: 0;
                }
                .dx-mobile-panel .nav-item {
                    list-style: none;
                }
                .dx-mobile-panel .nav-link,
                .dx-mobile-panel .dropdown-item,
                .dx-mobile-panel .list-group-item {
                    display: block;
                    padding: 14px 16px !important;
                    border-radius: 18px !important;
                    border: 1px solid rgba(33,37,41,0.08) !important;
                    background: rgba(255,255,255,0.78) !important;
                    color: var(--dx-charcoal) !important;
                    font-size: 14px;
                    font-weight: 700;
                    text-decoration: none !important;
                    margin-bottom: 10px;
                }
                .dx-mobile-panel .nav-link:hover,
                .dx-mobile-panel .dropdown-item:hover,
                .dx-mobile-panel .list-group-item:hover,
                .dx-mobile-panel .nav-link.active {
                    background: rgba(192,57,43,0.08) !important;
                    color: var(--dx-primary-hover) !important;
                }
                .dx-mobile-panel .accordion-item,
                .dx-mobile-panel .accordion-button {
                    border: 0 !important;
                    background: transparent !important;
                    box-shadow: none !important;
                }
                .dx-mobile-panel .accordion-body,
                .dx-mobile-panel .dropdown-menu {
                    display: block !important;
                    padding: 0 !important;
                    border: 0 !important;
                    background: transparent !important;
                    box-shadow: none !important;
                    position: static !important;
                    transform: none !important;
                    opacity: 1 !important;
                    visibility: visible !important;
                }
                .dx-mobile-panel .o_mega_nav,
                .dx-mobile-panel div.o_mega_menu,
                .dx-mobile-panel .o_mega_menu section {
                    position: static !important;
                    inset: auto !important;
                    height: auto !important;
                    margin: 0 !important;
                    padding: 0 !important;
                    border: 0 !important;
                    box-shadow: none !important;
                    opacity: 1 !important;
                    visibility: visible !important;
                    transform: none !important;
                    background: transparent !important;
                }
                .dx-mobile-section {
                    margin-top: 20px;
                    padding-top: 18px;
                    border-top: 1px solid rgba(33,37,41,0.08);
                }
                .dx-mobile-label {
                    font-size: 11px;
                    font-weight: 800;
                    letter-spacing: 0.16em;
                    text-transform: uppercase;
                    color: rgba(33,37,41,0.5);
                    margin-bottom: 12px;
                }
                .dx-footer {
                    position: relative;
                    overflow: hidden;
                    background: radial-gradient(circle at top right, rgba(192,57,43,0.18), transparent 30%), linear-gradient(180deg, var(--dx-charcoal) 0%, var(--dx-charcoal-soft) 100%);
                    color: rgba(255,255,255,0.74);
                    padding: 88px 0 0;
                    margin-top: 0;
                }
                .dx-footer-grid {
                    display: grid;
                    grid-template-columns: 1.3fr 0.85fr 0.85fr 1fr 0.9fr;
                    gap: 36px;
                    padding-bottom: 48px;
                    border-bottom: 1px solid rgba(255,255,255,0.1);
                }
                .dx-footer-title {
                    margin: 0 0 18px;
                    color: #fff;
                    font-family: var(--dx-font-head);
                    font-size: 24px;
                    line-height: 1.15;
                }
                .dx-footer h4 {
                    margin: 0 0 16px;
                    color: #fff;
                    font-size: 15px;
                    font-weight: 800;
                    letter-spacing: 0.08em;
                    text-transform: uppercase;
                }
                .dx-footer p,
                .dx-footer li,
                .dx-footer a {
                    color: rgba(255,255,255,0.72) !important;
                    font-size: 14px;
                    line-height: 1.8;
                    text-decoration: none !important;
                }
                .dx-footer a:hover { color: #fff !important; }
                .dx-footer ul {
                    list-style: none;
                    margin: 0;
                    padding: 0;
                    display: grid;
                    gap: 10px;
                }
                .dx-social-links {
                    display: flex;
                    flex-wrap: wrap;
                    gap: 12px;
                }
                .dx-social-link {
                    width: 46px;
                    height: 46px;
                    border-radius: 50%;
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    background: rgba(255,255,255,0.08);
                    border: 1px solid rgba(255,255,255,0.14);
                    color: #fff !important;
                    transition: transform 0.2s ease, background 0.2s ease, border-color 0.2s ease;
                }
                .dx-social-link:hover {
                    transform: translateY(-2px);
                    background: rgba(255,255,255,0.14);
                    border-color: rgba(255,255,255,0.24);
                }
                .dx-social-link svg {
                    width: 20px;
                    height: 20px;
                    display: block;
                }
                .dx-footer-badge {
                    display: inline-flex;
                    align-items: center;
                    gap: 8px;
                    padding: 8px 14px;
                    border-radius: 999px;
                    background: rgba(192,57,43,0.14);
                    color: #f1f2f4;
                    font-size: 11px;
                    font-weight: 800;
                    letter-spacing: 0.16em;
                    text-transform: uppercase;
                    margin-bottom: 18px;
                }
                .dx-footer-bottom {
                    display: flex;
                    align-items: center;
                    justify-content: space-between;
                    gap: 16px;
                    padding: 22px 0 28px;
                    font-size: 12px;
                    color: rgba(255,255,255,0.48);
                }
                .dx-whatsapp-float {
                    position: fixed;
                    inset-inline-end: 24px;
                    bottom: 24px;
                    width: 60px;
                    height: 60px;
                    border-radius: 50%;
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    background: linear-gradient(135deg, #25d366, #17b553);
                    color: #fff !important;
                    box-shadow: 0 20px 40px -18px rgba(37,211,102,0.7);
                    z-index: 1050;
                }
                .dx-whatsapp-float svg {
                    width: 28px;
                    height: 28px;
                }
                @media (max-width: 1199px) {
                    .dx-nav, .dx-actions { display: none !important; }
                }
                @media (max-width: 991px) {
                    .dx-topbar { display: none; }
                    .dx-header-row { min-height: 82px; }
                    .dx-logo-card img { height: 44px; }
                    .dx-footer-grid { grid-template-columns: 1fr 1fr; }
                    .dx-footer-bottom { flex-direction: column; align-items: flex-start; }
                }
                @media (max-width: 575px) {
                    .dx-header-row { min-height: 74px; gap: 12px; }
                    .dx-mobile-panel.offcanvas {
                        --bs-offcanvas-width: calc(100vw - 16px);
                        width: calc(100vw - 16px);
                        max-width: calc(100vw - 16px);
                    }
                    .dx-mobile-panel .offcanvas-body {
                        padding: 18px 16px 24px;
                    }
                    .dx-logo-card img { height: 40px; }
                    .dx-footer { padding-top: 70px; }
                    .dx-footer-grid { grid-template-columns: 1fr; }
                    .dx-whatsapp-float {
                        inset-inline-end: 16px;
                        bottom: 16px;
                        width: 56px;
                        height: 56px;
                    }
                }
            </style>
            <script>
                (function () {
                    var html = document.documentElement;
                    var lang = (html.getAttribute('lang') || '').toLowerCase();
                    if (lang.indexOf('ar') === 0) {
                        html.setAttribute('dir', 'rtl');
                    } else {
                        html.setAttribute('dir', 'ltr');
                    }
                })();
            </script>
        </xpath>
    </template>

    <template id="dx_header" name="DX Header">
        <t t-set="dx_is_public" t-value="request.env.user._is_public()"/>
        <t t-set="dx_cart_quantity" t-value="request.session.get('website_sale_cart_quantity', 0) or 0"/>

        <div class="dx-topbar">
            <div class="dx-shell dx-topbar-inner">
                <div class="dx-topbar-copy">
                    <span>Bathroom renovation &amp; design</span>
                    <a href="tel:+353879394509">+353 87 939 4509</a>
                    <a href="mailto:info@craikcomfort.ie">info@craikcomfort.ie</a>
                </div>
                <div class="dx-topbar-copy">
                    <span>D15XC91, Ireland</span>
                    <a href="/request-quote">Request a Quote</a>
                </div>
            </div>
        </div>

        <t t-call="website.navbar" _navbar_classes.f="dx-header-main d-none d-xl-block shadow-sm">
            <div id="o_main_nav" class="o_main_nav dx-shell dx-header-row">
                <a href="/" class="dx-logo-card navbar-brand me-0">
                    <img src="/digitalx_website/static/src/img/craikcomfort/logo.webp" alt="Craik &amp; Comfort" loading="eager"/>
                </a>

                <t t-call="website.navbar_nav" _nav_class.f="dx-nav mx-auto">
                    <t t-foreach="website.menu_id.child_id" t-as="submenu">
                        <t t-call="website.submenu"
                            item_class.f="nav-item"
                            link_class.f="nav-link dx-nav-link"
                            dropdown_menu_classes.f="dx-nav-menu"/>
                    </t>
                </t>

                <ul class="dx-actions navbar-nav align-items-center gap-2 flex-shrink-0 justify-content-end ps-0">
                    <li><a href="/bathroom-supply-shop" class="dx-text-link">Supply &amp; Shop</a></li>
                    <li><a href="/before-after-projects" class="dx-icon-pill">Projects</a></li>
                    <li>
                        <a t-att-href="dx_is_public and '/web/login' or '/my/home'" class="dx-text-link">
                            <t t-if="dx_is_public">Sign In</t>
                            <t t-else="">My Account</t>
                        </a>
                    </li>
                    <li class="o_wsale_my_cart position-relative">
                        <a href="/shop/cart" class="dx-cart-pill" aria-label="eCommerce cart">
                            <span>Cart</span>
                            <strong t-attf-class="my_cart_quantity #{'d-none' if (dx_cart_quantity == 0) else ''}"
                                    t-att-data-order-id="request.session.get('sale_order_id', '')">
                                <t t-esc="int(dx_cart_quantity)"/>
                            </strong>
                        </a>
                    </li>
                    <li><a href="/contactus" class="dx-cta-link">Book a Consultation</a></li>
                </ul>
            </div>
        </t>

        <t t-set="is_mobile" t-value="True"/>
        <t t-call="website.navbar"
            _navbar_classes.f="dx-header-main o_header_mobile d-block d-xl-none shadow-sm"
            _navbar_expand_class.f=""
            _navbar_name.f="Mobile">
            <div class="o_main_nav dx-shell dx-header-row">
                <div class="d-flex flex-grow-1 align-items-center">
                    <a href="/" class="dx-logo-card">
                        <img src="/digitalx_website/static/src/img/craikcomfort/logo.webp" alt="Craik &amp; Comfort" loading="eager"/>
                    </a>
                    <ul class="o_header_mobile_buttons_wrap navbar-nav d-flex flex-row align-items-center gap-2 mb-0 ms-auto">
                        <li class="o_wsale_my_cart position-relative">
                            <a href="/shop/cart" class="dx-cart-pill" aria-label="eCommerce cart">
                                <span>Cart</span>
                                <strong t-attf-class="my_cart_quantity #{'d-none' if (dx_cart_quantity == 0) else ''}"
                                        t-att-data-order-id="request.session.get('sale_order_id', '')">
                                    <t t-esc="int(dx_cart_quantity)"/>
                                </strong>
                            </a>
                        </li>
                    </ul>
                </div>

                <button class="dx-mobile-toggle nav-link btn p-2 o_not_editable" type="button" data-bs-toggle="offcanvas" data-bs-target="#top_menu_collapse_mobile" aria-controls="top_menu_collapse_mobile" aria-expanded="false" aria-label="Toggle navigation">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                        <line x1="4" y1="7" x2="20" y2="7"/>
                        <line x1="4" y1="12" x2="20" y2="12"/>
                        <line x1="4" y1="17" x2="20" y2="17"/>
                    </svg>
                </button>

                <div class="offcanvas offcanvas-end o_navbar_mobile dx-mobile-panel" id="top_menu_collapse_mobile">
                    <div class="offcanvas-header justify-content-end o_not_editable">
                        <button type="button" class="nav-link btn-close" data-bs-dismiss="offcanvas" aria-label="Close"/>
                    </div>
                    <div class="offcanvas-body d-flex flex-column justify-content-between h-100 w-100 pt-0">
                        <a href="/" class="dx-mobile-logo">
                            <img src="/digitalx_website/static/src/img/craikcomfort/logo.webp" alt="Craik &amp; Comfort"/>
                        </a>

                        <ul class="navbar-nav">
                            <li>
                                <t t-set="is_vertical_nav" t-value="True"/>
                                <t t-call="website.navbar_nav" _no_autohide_menu_mobile.f="True">
                                    <t t-set="offcanvas_is_leftside" t-valuef=""/>
                                    <t t-foreach="website.menu_id.child_id" t-as="submenu">
                                        <t t-call="website.submenu"
                                            item_class.f="nav-item border-top #{submenu_last and 'border-bottom'}"
                                            link_class.f="nav-link p-3 text-wrap"
                                            dropdown_toggler_classes.f="d-flex justify-content-between align-items-center"
                                            dropdown_menu_classes.f="position-relative rounded-0 o_dropdown_without_offset"/>
                                    </t>
                                </t>
                            </li>
                        </ul>

                        <div class="dx-mobile-section">
